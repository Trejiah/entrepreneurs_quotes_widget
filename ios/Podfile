# Uncomment this line to define a global platform for your project
platform :ios, '16.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks! :linkage => :static

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    
    # Ne modifier que les targets iOS (pas macOS)
    next unless target.platform_name == :ios
    
    # Aligner les pods sur la plateforme du Podfile (évite ld: built for X linked for Y)
    target.build_configurations.each do |config|
      deployment_target = config.build_settings['IPHONEOS_DEPLOYMENT_TARGET']
      if deployment_target.nil? || deployment_target.to_f < 16.0
        config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '16.0'
      end
      # S'assurer que Swift 5.5+ est utilisé pour la concurrency (RevenueCat)
      if target.name == 'RevenueCat' || target.name.include?('RevenueCat')
        config.build_settings['SWIFT_VERSION'] = '5.5'
      end
    end
  end
  
  # Fix RevenueCat SubscriptionPeriod ambiguity
  fix_revenuecat_subscription_period(installer)
end

def fix_revenuecat_subscription_period(installer)
  # Utiliser installer.sandbox.root pour obtenir le chemin absolu des Pods
  pods_root = installer.sandbox.root.to_s

  {
    'PurchasesHybridCommon/ios/PurchasesHybridCommon/PurchasesHybridCommon/StoreProduct+HybridAdditions.swift' => [
      [/static func rc_normalized\(subscriptionPeriod: SubscriptionPeriod\)/,
       'static func rc_normalized(subscriptionPeriod: RevenueCat.SubscriptionPeriod)'],
      [/static func rc_normalized\(subscriptionPeriodUnit: SubscriptionPeriod\.Unit\)/,
       'static func rc_normalized(subscriptionPeriodUnit: RevenueCat.SubscriptionPeriod.Unit)'],
    ],
    'PurchasesHybridCommon/ios/PurchasesHybridCommon/PurchasesHybridCommon/StoreProductDiscount+HybridAdditions.swift' => [
      [/StoreProduct\.rc_normalized\(subscriptionPeriod: subscriptionPeriod\)(?! as RevenueCat)/,
       'StoreProduct.rc_normalized(subscriptionPeriod: subscriptionPeriod as RevenueCat.SubscriptionPeriod)'],
      [/StoreProduct\.rc_normalized\(subscriptionPeriodUnit: subscriptionPeriod\.unit\)(?! as RevenueCat)/,
       'StoreProduct.rc_normalized(subscriptionPeriodUnit: subscriptionPeriod.unit as RevenueCat.SubscriptionPeriod.Unit)'],
    ],
  }.each do |relative_path, replacements|
    full_path = File.join(pods_root, relative_path)
    next unless File.exist?(full_path)

    content = File.read(full_path)
    modified = false
    replacements.each do |pattern, replacement|
      if content.match?(pattern)
        content.gsub!(pattern, replacement)
        modified = true
      end
    end
    if modified
      File.write(full_path, content)
      puts "✅ [Podfile] Fixed RevenueCat SubscriptionPeriod ambiguity in #{File.basename(full_path)}"
    else
      puts "ℹ️ [Podfile] #{File.basename(full_path)} already patched or not found"
    end
  end
end
