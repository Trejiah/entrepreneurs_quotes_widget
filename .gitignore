# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Local environment / secrets — never commit
.env
*.env.local

# FlutterFire — contains project / app IDs; generate locally with `flutterfire configure`
firebase.json

# Firebase real config (use *.example variants as templates;
# regenerate the real ones with `flutterfire configure`)
lib/firebase_options.dart
ios/Runner/GoogleService-Info.plist
ios/firebase_app_id_file.json
android/app/google-services.json

# Local-only tooling and history-purge backups
.tools/
.git-backup-prepurge/
.git-backup-prepurge2/
.git-postpurge-broken/

# Generic build dirs that may slip through
android/build/
build/

# macOS-specific lockfile (we keep ios/Podfile.lock only)
macos/Podfile.lock
