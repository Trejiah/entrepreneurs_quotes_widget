# Copy this file to `.env` and fill in your own values.
# `.env` is gitignored — never commit real credentials.
#
# All keys can also be supplied via `--dart-define=KEY=value` at build time
# (this takes precedence over .env).

# ---- Google Sign-In (Android) ----
# Web client ID from Firebase Console → Project settings → Your apps → Web app,
# or Google Cloud Console → APIs & Services → Credentials (OAuth 2.0 Client ID type "Web").
GOOGLE_ANDROID_SERVER_CLIENT_ID=YOUR_PROJECT.apps.googleusercontent.com

# ---- RevenueCat ----
# Public SDK keys from https://app.revenuecat.com/projects -> API keys
REVENUECAT_IOS_KEY=appl_YOUR_IOS_PUBLIC_KEY
REVENUECAT_ANDROID_KEY=goog_YOUR_ANDROID_PUBLIC_KEY
# Entitlement identifier configured in RevenueCat (case-sensitive)
REVENUECAT_ENTITLEMENT_ID=Premium

# ---- Subscription product IDs ----
# Must match the IDs configured in App Store Connect / Play Console
IOS_ANNUAL_SUBSCRIPTION_ID=premium_annual
IOS_MONTHLY_SUBSCRIPTION_ID=premium_monthly
ANDROID_ANNUAL_SUBSCRIPTION_ID=premium_annual
ANDROID_MONTHLY_SUBSCRIPTION_ID=premium_monthly

# Variants used for trial-length A/B tests and promo paywalls
IOS_ANNUAL_SUBSCRIPTION_ID_14=premium_annual_14
ANDROID_ANNUAL_SUBSCRIPTION_ID_14=premium_annual_14
IOS_ANNUAL_SUBSCRIPTION_ID_3_DAY_TRIAL_AB=premium_annual_3
ANDROID_ANNUAL_SUBSCRIPTION_ID_3_DAY_TRIAL_AB=premium_annual_3
IOS_ANNUAL_SUBSCRIPTION_ID_PROMO=premium_annual_promo
ANDROID_ANNUAL_SUBSCRIPTION_ID_PROMO=premium_annual_promo

# ---- Mixpanel ----
# Project token from https://mixpanel.com/project/<id>/settings#tokens
MIXPANEL_TOKEN=YOUR_MIXPANEL_PROJECT_TOKEN

# ---- TikTok Events SDK ----
# Two TikTok Ads accounts in our setup: one for the US store, one for ROW
TIKTOK_ANDROID_APP_ID=
TIKTOK_ANDROID_ID=
TIKTOK_IOS_APP_ID_US=
TIKTOK_IOS_ID_US=
TIKTOK_IOS_APP_ID_ROW=
TIKTOK_IOS_ID_ROW=
